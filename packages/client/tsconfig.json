{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@proj/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
